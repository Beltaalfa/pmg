# Copie para .env e preencha. Não commite o .env.
# Importante: não use espaço antes do nome da variável (senão PG* não é lido e o erro vira SCRAM/password).

# --- Espelho ERP (North) — leitura analítica só aqui; produção só entra em PMG_SOURCE_* ---
# Subir Postgres local: docker compose -f deploy/postgres-mirror-docker-compose.yml up -d
# Gerar DDL a partir da prod (só SELECT): npm run mirror:introspect
# Aplicar: psql "$DATABASE_URL" -f deploy/sql/mirror/generated_schema.sql
# Cópia inicial: npm run mirror:sync
#
# Base onde a app PMG corre as queries tab_* (espelho). Não use a base de produção aqui.
# DATABASE_URL=postgresql://pmg_mirror:senha@127.0.0.1:5433/pmg_erp_mirror
#
# Produção / ERP: só leitura (introspect + mirror:sync). Não precisa de DDL na prod.
# PMG_SOURCE_DATABASE_URL=postgresql://leitura:senha@host-producao:5432/erp?sslmode=require
# Esquema das tabelas tab_* na origem (normalmente public).
# PMG_SOURCE_SCHEMA=public
#
# Opcional: destino explícito do sync se DATABASE_URL for outra coisa na shell.
# PMG_MIRROR_DATABASE_URL=postgresql://pmg_mirror:senha@127.0.0.1:5433/pmg_erp_mirror
# PMG_MIRROR_BATCH_SIZE=5000

# Opção alternativa: variáveis PG* em vez de DATABASE_URL (mesmo host = espelho North)
# PGHOST=127.0.0.1
# PGPORT=5433
# PGUSER=pmg_mirror
# PGPASSWORD=
# PGDATABASE=pmg_erp_mirror

# Porta local do Next.js em produção (systemd / nginx apontam para 3008)
PORT=3008

# --- Metadados north/hub (setores = modelo Prisma "Group"; não usamos "Sector") ---
# URL read-only do mesmo PostgreSQL do Hub (ou réplica).
# HUB_DATABASE_URL=postgresql://hub_leitura:senha@host:5432/hub_db?sslmode=require
#
# Filtro obrigatório: um dos dois (limita setores a um cliente no Hub).
# HUB_CLIENT_ID=clxxxxxxxxxxxxxxxxxxxxxxxx
# HUB_CLIENT_NAME=Rede PMG

# --- Cache local (Quantidade x Margem) — sem DDL no Postgres do cliente ---
# Modo: "direct" = JOIN nas tab_* do espelho; "cache" = lê pmg_cache.quantidade_margem (rápido, requer job sync).
# PMG_QUANTIDADE_MARGEM_MODE=direct
#
# Cache curto na API (segundos): mesmo filtro repetido fica instantâneo até expirar (0 = desligado).
# PMG_QUANTIDADE_MARGEM_API_CACHE_SECONDS=300
#
# Aba "Quantidade × Margem até o dia e projeção": "direct" = SQL no espelho incluindo operador 367;
# omisso ou "cache" = lê pmg_cache.quantidade_margem_projecao (preenchida no mesmo job que quantidade_margem).
# PMG_QUANTIDADE_MARGEM_PROJECAO_MODE=cache
# PMG_QUANTIDADE_MARGEM_PROJECAO_API_CACHE_SECONDS=300
#
# Opcional: tamanho máximo do pool pg para o espelho (default 15, máx. 50). Útil com vários pedidos em paralelo.
# PMG_PG_POOL_MAX=15
#
# (PMG_SOURCE_DATABASE_URL já está na secção espelho acima.)
#
# Após 001, opcional: psql "$DATABASE_URL" -f deploy/sql/003_pmg_cache_quantidade_margem_perf.sql (índice na tabela de cache).
# Projeção (inclui operador 367): psql "$DATABASE_URL" -f deploy/sql/005_pmg_cache_quantidade_margem_projecao.sql
#
# Destino do cache (normalmente igual a DATABASE_URL quando a app usa só o cache para dados espelhados).
# PMG_CACHE_DATABASE_URL=postgresql://pmg:senha@127.0.0.1:5432/pmg_cache
#
# Janela de dados replicada no TRUNCATE+INSERT (ISO date YYYY-MM-DD). Omisso: 1 jan do ano atual → hoje.
# PMG_SYNC_DATE_START=2026-01-01
# PMG_SYNC_DATE_END=2026-04-09
#
# Segredo para a página /admin/cache-quantidade-margem: leitura do estado (GET) e sync manual (POST), header Authorization: Bearer.
# PMG_ADMIN_SYNC_SECRET=gere_um_segredo_longo_aleatorio
#
# Opcional: mesmo valor que PMG_ADMIN_SYNC_SECRET — pré-preenche a página e carrega o estado ao abrir.
# O valor vai no bundle JS (NEXT_PUBLIC_*); só use em ambiente confiável (VPN / rede interna).
# NEXT_PUBLIC_PMG_ADMIN_UI_TOKEN=gere_um_segredo_longo_aleatorio
